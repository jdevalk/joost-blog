---
import BaseLayout from '../layouts/BaseLayout.astro';
import Search from 'astro-pagefind/components/Search';
---

<BaseLayout title="Search" description="Search all posts and pages on Joost.blog">
    <main class="max-w-4xl mx-auto px-4 py-8 sm:py-12 grow">
        <h1 class="text-3xl font-bold mb-8 dark:text-slate-100">Search</h1>
        <div data-pagefind-ignore="all">
            <Search id="search" className="pagefind-ui" uiOptions={{ showSubResults: true, showImages: true, showEmptyFilters: false, pageSize: 10, resetStyles: true }} />
        </div>
    </main>
</BaseLayout>

<style is:global>
    :root {
        --pagefind-ui-scale: 1;
        --pagefind-ui-primary: #3b82f6;
        --pagefind-ui-text: #334155;
        --pagefind-ui-background: #ffffff;
        --pagefind-ui-border: #e2e8f0;
        --pagefind-ui-tag: #f1f5f9;
        --pagefind-ui-border-width: 1px;
        --pagefind-ui-border-radius: 8px;
        --pagefind-ui-image-border-radius: 8px;
        --pagefind-ui-image-box-ratio: 3 / 2;
        --pagefind-ui-font: inherit;
    }

    .dark {
        --pagefind-ui-primary: #60a5fa;
        --pagefind-ui-text: #e2e8f0;
        --pagefind-ui-background: #1e293b;
        --pagefind-ui-border: #334155;
        --pagefind-ui-tag: #334155;
    }
</style>

<script>
    function syncSearchInputFromUrl() {
        const input = document.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
        if (!input) return;

        const query = new URLSearchParams(window.location.search).get('q') || '';
        if (input.value !== query) {
            input.value = query;
            input.dispatchEvent(new Event('input', { bubbles: true }));
        }
    }

    function initSearch() {
        // Wait for Pagefind UI to render its input, then sync query and wire URL sync once.
        const observer = new MutationObserver(() => {
            const input = document.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
            if (!input) return;
            observer.disconnect();

            syncSearchInputFromUrl();

            if (input.dataset.urlSyncBound === 'true') return;
            input.dataset.urlSyncBound = 'true';

            input.addEventListener('input', () => {
                const url = new URL(window.location.href);
                if (input.value) {
                    url.searchParams.set('q', input.value);
                } else {
                    url.searchParams.delete('q');
                }
                history.replaceState(null, '', url.toString());
            });
        });

        observer.observe(document.body, { childList: true, subtree: true });
    }

    initSearch();
    window.addEventListener('pageshow', syncSearchInputFromUrl);
    window.addEventListener('popstate', syncSearchInputFromUrl);
</script>
