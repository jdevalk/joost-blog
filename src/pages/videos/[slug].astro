---
import { getCollection, render } from 'astro:content';
import JsonLd from '../../components/JsonLd.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';

export async function getStaticPaths() {
    const videos = await getCollection('videos');
    return videos.map((video) => ({
        params: { slug: video.id },
        props: { video }
    }));
}

const { video } = Astro.props;
const { Content } = await render(video);

function formatDuration(isoDuration: string | undefined): string | null {
    if (!isoDuration) return null;
    const match = isoDuration.match(/PT(?:(\d+)H)?(?:(\d+)M)?(?:(\d+)S)?/);
    if (!match) return null;
    const hours = parseInt(match[1] || '0');
    const minutes = parseInt(match[2] || '0');
    const seconds = parseInt(match[3] || '0');
    if (hours > 0) {
        return `${hours}:${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
    }
    return `${minutes}:${String(seconds).padStart(2, '0')}`;
}

const duration = formatDuration(video.data.duration);

const videoSchema = video.data.youtubeId ? {
    "@context": "https://schema.org",
    "@type": "VideoObject",
    "name": video.data.title,
    "description": video.data.title,
    "thumbnailUrl": `https://img.youtube.com/vi/${video.data.youtubeId}/maxresdefault.jpg`,
    "uploadDate": video.data.publishDate.toISOString(),
    ...(video.data.duration && { "duration": video.data.duration }),
    "embedUrl": `https://www.youtube-nocookie.com/embed/${video.data.youtubeId}`
} : null;
---

<BaseLayout title={`${video.data.title} - joost.blog`} description={video.data.title}>
    {videoSchema && <JsonLd schema={videoSchema} />}
    <main class="grow px-4 py-12 sm:px-8">
        <div class="max-w-4xl mx-auto">
            <h1 class="text-4xl font-bold mb-6 text-slate-900 dark:text-slate-100">{video.data.title}</h1>
            {duration && (
                <p class="text-sm text-slate-500 dark:text-slate-400 mb-6">Duration: {duration}</p>
            )}
            {video.data.youtubeId && (
                <div class="mb-8">
                    <YouTubeEmbed youtubeId={video.data.youtubeId} title={video.data.title} />
                </div>
            )}
            <div class="prose prose-slate dark:prose-invert max-w-none">
                <Content />
            </div>
        </div>
    </main>
</BaseLayout>
