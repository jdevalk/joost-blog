---
import type { GetStaticPathsOptions, Page } from 'astro';
import { type CollectionEntry, getCollection } from 'astro:content';
import Icon from '../../components/Icon.astro';
import PostPreview from '../../components/PostPreview.astro';
import Subscribe from '../../components/Subscribe.astro';
import siteConfig from '../../data/site-config';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaGraph from '../../components/SchemaGraph.astro';
import type { SchemaPageContext } from '../../utils/schema';
import { canonicalUrl } from '../../utils/schema/constants';
import { sortPostsByDateDesc } from '../../utils/post-utils';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const posts = (await getCollection('blog')).sort(sortPostsByDateDesc);
    return paginate(posts, { pageSize: siteConfig.postsPerPage || 5 });
}

const { page } = Astro.props as { page: Page<CollectionEntry<'blog'>> };
const blog = page.data;

const pageContext: SchemaPageContext = {
    pageType: 'blogListing',
    canonicalUrl: canonicalUrl(Astro.url.pathname),
    title: 'Blog',
    description: 'Articles about WordPress, SEO, open source, and more by Joost de Valk'
};
---

<BaseLayout title="Blog" description="Articles about WordPress, SEO, open source, and more by Joost de Valk">
    <SchemaGraph pageContext={pageContext} />
    <main class="px-4 py-12 grow sm:px-8 sm:py-16" data-pagefind-ignore="all">
        <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100 mb-8 sm:text-4xl max-w-3xl mx-auto xl:max-w-6xl">Blog</h1>
        <div class="max-w-3xl mx-auto xl:max-w-6xl">
            {blog.map((post) => <PostPreview post={post} />)}
        </div>
        <nav aria-label="Pagination" class="max-w-3xl pt-12 mx-auto my-12 border-t border-slate-200 dark:border-slate-700 sm:my-16 sm:pt-16">
            <div class="relative px-12 text-center">
                {
                    page.url.prev && (
                        <a
                            class="absolute left-0 inline-flex items-center justify-center w-10 h-10 text-lg transition duration-300 -translate-y-1/2 rounded-full hover:bg-primary hover:shadow-button top-1/2 bg-slate-50 text-slate-700 hover:text-white dark:bg-slate-800 dark:text-slate-200"
                            href={page.url.prev}
                            rel="prefetch"
                            aria-label={`Go to page ${page.currentPage - 1} of ${page.lastPage}`}
                        >
                            <Icon icon="arrow-left" class="w-5 h-5 fill-current" />
                        </a>
                    )
                }
                <span class="text-sm tracking-wider uppercase text-slate-500 dark:text-slate-400" aria-current="page">Page {page.currentPage} of {page.lastPage}</span>
                {
                    page.url.next && (
                        <a
                            class="absolute right-0 inline-flex items-center justify-center w-10 h-10 text-lg transition duration-300 -translate-y-1/2 rounded-full hover:bg-primary hover:shadow-button top-1/2 bg-slate-50 text-slate-700 hover:text-white dark:bg-slate-800 dark:text-slate-200"
                            href={page.url.next}
                            rel="prefetch"
                            aria-label={`Go to page ${page.currentPage + 1} of ${page.lastPage}`}
                        >
                            <Icon icon="arrow-right" class="w-5 h-5 fill-current" />
                        </a>
                    )
                }
            </div>
        </nav>
        <Subscribe class="my-12 sm:my-16" />
    </main>
</BaseLayout>
