---
import siteConfig from '../data/site-config';
import SocialLink from './SocialLink.astro';

const socialLinks = siteConfig.socialLinks ?? [];
const currentYear = new Date().getFullYear();
---

<footer class="px-4 py-8 sm:px-8 sm:py-12">
    {
        socialLinks.length > 0 && (
            <div class="flex flex-wrap justify-center w-full max-w-3xl mx-auto mb-6 gap-x-4 gap-y-3">
                {socialLinks.map((link) => (
                    <SocialLink {...link} class="hover:bg-primary hover:shadow-button bg-slate-50 text-slate-700 hover:text-white" />
                ))}
            </div>
        )
    }
    <p class="text-xs tracking-wider text-center uppercase text-slate-700">
        &copy; {currentYear} <a class="underline text-primary hover:no-underline" href="/">{siteConfig.title}</a>
    </p>
</footer>
