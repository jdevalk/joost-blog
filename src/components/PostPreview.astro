---
import { type CollectionEntry } from 'astro:content';
import CustomImage from './CustomImage.astro';
import FormattedDate from './FormattedDate.astro';
import { slugify, getReadingTime } from '../utils/post-utils';

const { post } = Astro.props as { post: CollectionEntry<'blog'> };
const { title, publishDate, updatedDate, featureImage, excerpt, isFeatured, categories } = post.data;
const readingTime = getReadingTime(post.body ?? '');
---

<article class="mb-12 post-card sm:mb-16">
    <header class="post-card-header">
        <div class="mb-2 text-sm tracking-wider uppercase text-slate-500 dark:text-slate-400">
            {
                categories && categories.length > 0 && (
                    <>
                        {categories.map((cat: string, i: number) => (
                            <>
                                <a
                                    href={`/category/${slugify(cat)}/`}
                                    class="text-primary hover:text-slate-700 dark:text-accent dark:hover:text-slate-300 transition duration-300"
                                >
                                    {cat}
                                </a>
                                {i < categories.length - 1 && ', '}
                            </>
                        ))}
                        {' / '}
                    </>
                )
            }
            <FormattedDate date={publishDate} />
            {
                updatedDate && (
                    <>
                        {' '}
                        <span>
                            (Updated on <FormattedDate date={updatedDate} />)
                        </span>
                    </>
                )
            }
            <span> / {readingTime} min read</span>
        </div>
        <h2 class="text-3xl font-bold text-slate-900 dark:text-slate-100"><a href={`/${post.id}/`}>{title}</a></h2>
    </header>
    {
        featureImage?.src && (
            <figure class="mt-6 mb-6 post-card-thumbnail xl:mt-7 xl:mb-0">
                <a href={`/${post.id}/`}>
                    <CustomImage
                        {...featureImage}
                        class="w-full rounded-md"
                        widths={[160, 320, 480, 640, 768, 960, 1200]}
                        sizes="(min-width: 1280px) 160px, (min-width: 832px) 768px, calc(100vw - 32px)"
                    />
                </a>
            </figure>
        )
    }
    {
        excerpt && (
            <div class="mt-4 post-card-content">
                <div class="prose prose-slate sm:prose-lg max-w-none">{excerpt}</div>
            </div>
        )
    }
</article>

<style>
    @reference "tailwindcss";

    @media (min-width: 1280px) {
        .post-card-header {
            grid-area: header;
        }
        .post-card-content {
            grid-area: content;
        }
        .post-card-thumbnail {
            grid-area: thumbnail;
        }
        .post-card {
            @apply grid gap-x-8;
            grid-template-rows: min-content 1fr;
            grid-template-columns: 1fr 768px 1fr;
            grid-template-areas:
                'thumbnail header'
                'thumbnail content';
        }
    }
</style>
