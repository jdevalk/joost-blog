---
import monaSansWoff2 from '@fontsource-variable/mona-sans/files/mona-sans-latin-wght-normal.woff2?url';
import { getImage } from 'astro:assets';
import siteConfig from '../data/site-config';
import { SITE_URL } from '../utils/schema/constants';
import type { ImageInput } from '../types';

import '../styles/global.css';

export type Props = {
    title?: string;
    description?: string;
    image?: ImageInput | undefined;
    ogImage?: string;
    pageType?: 'website' | 'article';
};

const { description = '', pageType = 'website' } = Astro.props;
const title = [Astro.props.title, siteConfig.title].filter(Boolean).join(' | ');

// Detect staging: Astro.site differs from production SITE_URL
const isStaging = Astro.site?.origin !== new URL(SITE_URL).origin;

// OG image resolution: prefer explicit ogImage prop, then auto-generated OG image from slug
const slug = Astro.url.pathname.replace(/^\/|\/$/g, '');
const autoOgImage = slug ? `/og/${slug}.png` : undefined;
const ogImageUrl = Astro.props.ogImage ?? autoOgImage;
// OG images must point to the actual deployed site (not production canonical) so they resolve
const ogImageBase = Astro.site?.origin ?? SITE_URL;
const ogImageSrc = ogImageUrl ? new URL(ogImageUrl, ogImageBase).toString() : undefined;

// Fallback image resolution for pages without auto-generated OG images
const image = Astro.props.image ?? siteConfig.image;
let resolvedImage: { src: string; alt?: string } | undefined;
if (!ogImageSrc && image?.src) {
    if (typeof image.src === 'string') {
        resolvedImage = {
            src: new URL(image.src, ogImageBase).toString(),
            alt: image.alt
        };
    } else {
        const optimizedImage = await getImage({
            src: image.src as ImageMetadata,
            width: 1200,
            height: 630,
            format: 'jpeg',
            fit: 'cover'
        });
        resolvedImage = {
            src: new URL(optimizedImage.src, ogImageBase).toString(),
            alt: image.alt
        };
    }
}

// Final OG image: auto-generated takes priority, then resolved from image prop
const finalOgImage = ogImageSrc ?? resolvedImage?.src;

// Canonical URL always points to production domain
const canonicalURL = new URL(Astro.url.pathname, SITE_URL);

/**
 * Enforce some standard canonical URL formatting across the site.
 */
function formatCanonicalURL(url: string | URL) {
    const path = url.toString();
    const hasQueryParams = path.includes('?');
    // If there are query params, make sure the URL has no trailing slash
    if (hasQueryParams) {
        path.replace(/\/?$/, '');
    }
    // otherwise, canonical URL always has a trailing slash
    return path.replace(/\/?$/, hasQueryParams ? '' : '/');
}
---

<!-- High Priority Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{title}</title>
<meta name="generator" content={Astro.generator} />

<!-- Font preloads -->
<link rel="preload" as="font" type="font/woff2" href={monaSansWoff2} crossorigin="anonymous" />

<!-- Low Priority Global Metadata -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" href="/rss.xml" title="RSS" />

<!-- Page Metadata -->
<link rel="canonical" href={formatCanonicalURL(canonicalURL)} />
<meta name="description" content={description} />
{isStaging && <meta name="robots" content="noindex, nofollow" />}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={pageType} />
<meta property="og:url" content={formatCanonicalURL(canonicalURL)} />
<meta property="og:title" content={title} />
{description && <meta property="og:description" content={description} />}
{finalOgImage && <meta property="og:image" content={finalOgImage} />}
{resolvedImage?.alt && <meta property="og:image:alt" content={resolvedImage.alt} />}

<!-- X/Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={formatCanonicalURL(canonicalURL)} />
<meta name="twitter:title" content={title} />
{description && <meta name="twitter:description" content={description} />}
{finalOgImage && <meta name="twitter:image" content={finalOgImage} />}
{resolvedImage?.alt && <meta name="twitter:image:alt" content={resolvedImage.alt} />}
